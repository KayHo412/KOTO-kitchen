  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialController
  steps:
  - instructionKey: Tutorial.Step1
    instruction: First, drag the pot on to the stove using your finger
    targetObject: {fileID: 1356094671945326941, guid: 162f7927fe6a94c7bbe7e6a6c625fca1, type: 3}
  - instructionKey: Tutorial.Step2
    instruction: Second, drag the kettle into the pot to pour water
    targetObject: {fileID: 206133592}
  - instructionKey: Tutorial.Step3
    instruction: Third, turn on the stove and wait for the water to boil
    targetObject: {fileID: 716642709}
  - instructionKey: Tutorial.Step4
    instruction: Drag the potato to the cutting board
    targetObject: {fileID: 892149669}
  - instructionKey: Tutorial.Step5
    instruction: Then drag the knife from the box to the ingredient
    targetObject: {fileID: 2063161902}
  - instructionKey: Tutorial.Step6
    instruction: Drag the cut ingredient to the pot
    targetObject: {fileID: 226672913}
  - instructionKey: Tutorial.Step7
    instruction: Do the same with the rest, look at the recipe to know what to choose
    targetObject: {fileID: 1095577988}
