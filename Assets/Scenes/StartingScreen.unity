  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "KOTO Kitchen is a project I am building to see if a digital kitchen can
    be easier to use than regular games. Most games feel too fast or have too many
    buttons, so I made this to be a slower experience where the main focus is just
    following a recipe at your own pace.\n\nThis is a student demo, so a lot of it
    is still unfinished. I am still working on things like the stirring mechanics
    and the visual effects for the stove. Because it is a work in progress, some
    parts might feel a bit rough or incomplete.\n\nI\u2019m sharing it now to see
    how the basic parts work for you. I hope it\u2019s a simple and relaxing way
    to spend a few minutes. Thanks for helping me test this for my studies.\n\nHappy
    cooking!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 27b985087eb1748d4a81210f5bf0b740, type: 2}
